# El dominio del FROM debe estar verificado en Resend y la API key autorizada para ese dominio.
# 2026-07-16: la key actual solo está autorizada para ctsoft.com.ar (Resend devolvió 403 con dacio.com.ar).
# Cuando la key tenga acceso a dacio.com.ar, cambiar a: Notificaciones DACIO <notificaciones@dacio.com.ar>
RESEND_API_KEY=
CONTACT_FROM_EMAIL=Notificaciones DACIO <dacio@ctsoft.com.ar>
CONTACT_TO_EMAIL=info@dacio.com.ar
